{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyCommander",
  "version": "1.1.32",
  "identifier": "com.mycommander.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MyCommander",
        "width": 1120,
        "height": 720,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$HOME/**",
            "$DESKTOP/**",
            "$DOCUMENT/**",
            "$DOWNLOAD/**",
            "$PICTURE/**",
            "$VIDEO/**",
            "$AUDIO/**",
            "$TEMP/**",
            "/Volumes/**"
          ],
          "deny": [
            "$HOME/.ssh/**",
            "$HOME/.gnupg/**",
            "$HOME/.aws/**",
            "$HOME/.kube/**",
            "$HOME/Library/Keychains/**"
          ],
          "requireLiteralLeadingDot": true
        }
      },
      "csp": {
        "default-src": [
          "'self'"
        ],
        "connect-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost"
        ],
        "img-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "data:"
        ],
        "media-src": [
          "'self'",
          "asset:",
          "http://asset.localhost"
        ],
        "frame-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "data:",
          "blob:",
          "about:"
        ],
        "style-src": [
          "'self'",
          "'unsafe-inline'"
        ],
        "font-src": [
          "'self'",
          "data:"
        ],
        "script-src": [
          "'self'"
        ],
        "object-src": [
          "'none'"
        ],
        "base-uri": [
          "'none'"
        ],
        "form-action": [
          "'none'"
        ]
      },
      "devCsp": {
        "default-src": [
          "'self'"
        ],
        "connect-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost",
          "http://127.0.0.1:*",
          "http://localhost:*",
          "ws://127.0.0.1:*",
          "ws://localhost:*"
        ],
        "img-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "data:"
        ],
        "media-src": [
          "'self'",
          "asset:",
          "http://asset.localhost"
        ],
        "frame-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "data:",
          "blob:",
          "about:"
        ],
        "style-src": [
          "'self'",
          "'unsafe-inline'"
        ],
        "font-src": [
          "'self'",
          "data:"
        ],
        "script-src": [
          "'self'",
          "'unsafe-eval'"
        ],
        "object-src": [
          "'none'"
        ],
        "base-uri": [
          "'none'"
        ],
        "form-action": [
          "'none'"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
