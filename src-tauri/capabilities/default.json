{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:default",
    "fs:allow-home-read-recursive",
    "fs:allow-home-write-recursive",
    "fs:allow-desktop-read-recursive",
    "fs:allow-desktop-write-recursive",
    "dialog:default",
    "shell:default",
    "allow-get-drives",
    "allow-get-home-dir",
    "allow-get-available-space",
    "allow-open-in-terminal",
    "allow-open-in-editor",
    "allow-open-file",
    "allow-run-shell-command",
    "allow-quit-app",
    "allow-set-show-hidden-menu-checked",
    "allow-set-theme-menu-selection",
    "allow-set-view-mode-menu-selection",
    "allow-list-directory",
    "allow-create-directory",
    "allow-create-file",
    "allow-delete-files",
    "allow-rename-file",
    "allow-copy-files",
    "allow-move-files",
    "allow-check-copy-conflicts",
    "allow-extract-zip",
    "allow-read-file-content",
    "allow-search-files",
    "allow-get-dir-size",
    "drag:default"
  ]
}
