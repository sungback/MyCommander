{
  "name": "mycommander",
  "private": true,
  "version": "1.1.32",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run --testTimeout=15000",
    "test:watch": "vitest",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:coverage": "vitest run --coverage",
    "test:all": "npm run test && npm run test:rust",
    "typecheck": "tsc --noEmit",
    "verify:frontend": "npm run typecheck && npm run test && npm run build",
    "verify:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings && npm run test:rust",
    "verify": "npm run verify:frontend && npm run verify:rust",
    "verify:release-version": "node scripts/verify-release-version.cjs",
    "verify:release": "npm run verify:release-version && npm run verify && npm run tauri build -- --bundles app",
    "release:push": "node scripts/push-release.cjs",
    "version": "node version-sync.cjs && git add src-tauri/tauri.conf.json src-tauri/Cargo.toml",
    "postversion": "echo \"Version updated locally. Push branch and tags explicitly when ready.\""
  },
  "dependencies": {
    "@crabnebula/tauri-plugin-drag": "^2.1.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.7.0",
    "marked": "^18.0.0",
    "re-resizable": "^6.11.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-resizable-panels": "^4.7.6",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jszip": "^3.4.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "jsdom": "^29.0.2",
    "lefthook": "^2.1.6",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.2"
  }
}
